# Environment Variables

# Gemini AI — Server-side shared key (RECOMMENDED)
# When set, ALL users share this key — no personal key needed.
# Get a free key at: https://aistudio.google.com/apikey
# If not set, users must provide their own key via the AI Settings panel.
GEMINI_API_KEY=your_gemini_api_key_here

# Encryption salt for personal API keys stored in browser localStorage.
# Change this to any random string. Does NOT need to be secret.
NEXT_PUBLIC_KEY_SALT=ncsstat-gemini-v2

NEXT_PUBLIC_APP_NAME=ncsStat
NEXT_PUBLIC_APP_URL=https://stat.ncskit.org

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ORCID OAuth Configuration
ORCID_CLIENT_ID=your-orcid-client-id
ORCID_CLIENT_SECRET=your-orcid-client-secret

# LinkedIn OAuth - Configure in Supabase Dashboard
# Go to: Supabase Dashboard > Authentication > Providers > LinkedIn OIDC

# Sentry Error Monitoring (optional but recommended for production)
# Get your DSN at: https://sentry.io
# Install: npm install @sentry/nextjs
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
