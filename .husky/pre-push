#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-push verification..."
echo "⚠️  This simulates Vercel's build process to catch errors early!"

# Run TypeScript type checking (same as Vercel)
echo ""
echo "📝 Step 1/3: TypeScript type checking..."
npm run type-check || {
  echo ""
  echo "❌ TypeScript errors detected!"
  echo "💡 Tip: Run 'npm run type-check' to see detailed errors"
  echo "🚫 Push blocked to prevent Vercel deployment failure"
  exit 1
}

# Run ESLint (same as Vercel)
echo ""
echo "🧹 Step 2/3: ESLint checking..."
npm run lint || {
  echo ""
  echo "⚠️  ESLint issues detected!"
  echo "💡 Tip: Some issues might be auto-fixable with 'npm run lint --fix'"
  echo "🚫 Push blocked to prevent Vercel deployment failure"
  exit 1
}

# Run production build (same as Vercel)
echo ""
echo "🏗️  Step 3/3: Production build test..."
npm run build || {
  echo ""
  echo "❌ Build failed!"
  echo "💡 This is the same error you would see on Vercel"
  echo "🚫 Push blocked to prevent Vercel deployment failure"
  exit 1
}

echo ""
echo "✅ All checks passed! Safe to push to Vercel 🎉"
echo ""
