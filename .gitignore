# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase temp
supabase/.temp/

# WebR Binaries (Large files, generated/copied during setup)
/public/webr_core/
/public/webr_core_v3/
# NOTE: /public/webr_repo_v3/ MUST be committed - these R packages are required at runtime
# and cannot be downloaded from external CDNs due to CSP restrictions on Vercel.

scripts/qwen-consultant.mjs
